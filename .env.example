# ============================================
# BARBERSAAS – Configuration
# Copiez ce fichier en ".env" et remplissez vos vraies valeurs
# NE JAMAIS committer le fichier .env sur GitHub
# ============================================

# --- SERVEUR ---
PORT=3000

# --- SESSION (générez une chaîne aléatoire longue) ---
SESSION_SECRET=changez_ceci_par_une_chaine_secrete_aleatoire_longue

# --- ADMIN ---
# Mot de passe admin (changez-le !)
ADMIN_PASSWORD=Fenix2024!

# --- SUPER ADMIN PLATEFORME (accès /superadmin) ---
SUPERADMIN_EMAIL=votre.email@exemple.com
SUPERADMIN_PASSWORD=changez_ce_mot_de_passe

# --- JWT (générez des secrets forts en production) ---
JWT_SECRET=fenix_jwt_secret_2024_changez_en_production
JWT_REFRESH_SECRET=fenix_refresh_secret_2024_changez_en_production

# --- STRIPE (abonnements SaaS) ---
# Créez un compte sur https://stripe.com
STRIPE_SECRET_KEY=sk_test_xxx_remplacez_par_vrai
STRIPE_WEBHOOK_SECRET=whsec_xxx_remplacez_par_vrai
# IDs des prix dans votre tableau de bord Stripe
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx

# --- URL DE L'APPLICATION ---
APP_URL=http://localhost:3000
TRIAL_DAYS=30

# --- TWILIO (SMS réels) ---
# Créez un compte sur https://www.twilio.com (essai gratuit)
# Tableau de bord Twilio > Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Numéro Twilio au format E.164 (ex: +15141234567)
TWILIO_PHONE_NUMBER=+15141234567

# --- NODEMAILER (courriels réels) ---
# Pour Gmail: activez "Mots de passe d'application" dans votre compte Google
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre.email@gmail.com
EMAIL_PASS=votre_mot_de_passe_application
EMAIL_FROM=Fenix Barbier <votre.email@gmail.com>

# --- INFOS DU SALON (tenant par défaut) ---
SHOP_NAME=Fenix Barbier
SHOP_PHONE=418-555-0100
SHOP_ADDRESS=155 Rue Des Chênes O, Quebec Qc G1L 1K6
